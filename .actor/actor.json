{
  "actorSpecification": 1,
  "name": "linkedin-profile-scraper",
  "title": "LinkedIn Profile Scraper",
  "description": "Scrape and enrich LinkedIn profiles with professional data.",
  "version": "1.0",
  "output": {
    "actorOutputSchemaVersion": 1,
    "title": "LinkedIn Profile Scraper Output",
    "description": "Scraped LinkedIn profile data including work experience, education, skills and more.",
    "properties": {
      "results": {
        "type": "string",
        "title": "LinkedIn Profiles",
        "template": "{{links.apiDefaultDatasetUrl}}/items"
      }
    }
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "overview": {
          "title": "Overview",
          "transformation": {
            "fields": [
              "publicIdentifier",
              "linkedInIdentifier",
              "memberIdentifier",
              "linkedInUrl",
              "firstName",
              "lastName",
              "headline",
              "summary",
              "location",
              "followerCount",
              "premium",
              "is_open_profile",
              "is_creator",
              "is_influencer",
              "is_self",
              "is_relationship",
              "websites",
              "connections_count",
              "birthdate",
              "positions",
              "schools",
              "skills",
              "languages",
              "recommendations",
              "volunteering_experience",
              "photoUrl",
              "backgroundUrl",
              "request_type"
            ]
          },
          "display": {
            "component": "table"
          }
        }
      }
    }
  }
}
